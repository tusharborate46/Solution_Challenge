# ==========================================
# CrisisSync Backend Environment Variables
# ==========================================

# Port for the Node.js server (Default: 5000)
PORT=5000

# Secret Key for JWT Authentication (Used in authController.js)
JWT_SECRET=super_secret_crisissync_key_123

# (Optional) MongoDB Connection String. 
# If left blank or commented out, the server defaults to an in-memory database
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/crisissync

# Google Gemini API Key for AI Triage System (aiService.js)
# Grab a free key at: https://aistudio.google.com/
GEMINI_API_KEY=AIzaSyDNDAImYa-Odv5DGpCC14JvygQNCoXpN1M

# Google Maps API Key for the Command Center Dashboard / Smart Dispatch System
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Placeholder Twilio / Firebase Secrets (for Future Implementation)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# FIREBASE_SERVER_KEY=
