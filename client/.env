# ==========================================
# CrisisSync Frontend Environment Variables
# ==========================================

# Add your Google Maps API Key here to remove the "Development Purposes Only" watermark
# You can generate a free billing key via the Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# When adding new variables to this file in the future, 
# remember they MUST start with "VITE_" to be read by the React framework.
